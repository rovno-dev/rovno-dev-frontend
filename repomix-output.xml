  ({ className, size = 24, children, ...props }, ref) => {
    return (
      <svg
        ref={ref}
        xmlns="http://w3.org"
        width={size}
        height={size}
        viewBox="0 0 50 50"
        fill="none"
        // stroke="currentColor"
