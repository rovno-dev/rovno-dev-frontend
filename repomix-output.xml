      title: `Motion-дизайн и 3D`,
      id: '2',
      icon: <DiamondIcon className={servicesIconsStyles} />
    },
    {
      count: '3',
      title: "Логотипы и айдентика",
      id: '3',
      icon: <StylusNoteIcon className={servicesIconsStyles} />
